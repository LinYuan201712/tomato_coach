# Tomato Study Room - 环境变量配置 (模板)

# --- 核心安全配置 ---
TOMATO_DB_PASSWORD=your_db_password
TOMATO_JWT_SECRET=your_jwt_secret

# --- 第三方 API 密钥 ---
ARK_API_KEY=your_ark_api_key
ALIYUN_API_KEY=your_aliyun_api_key
MINERU_TOKEN=your_mineru_token

# --- 可观测性 (Langfuse) ---
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=http://localhost:3000

# --- 飞书 (Feishu) ---
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_VERIFICATION_TOKEN=your_token
FEISHU_ENCRYPT_KEY=your_key

# MySQL 容器内部配置
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=tomato_study_room

# Langfuse 内部安全配置
LANGFUSE_NEXTAUTH_SECRET=your_nextauth_secret
LANGFUSE_SALT=your_salt
LANGFUSE_ENCRYPTION_KEY=your_64_char_hex_encryption_key

# --- 邮件配置 (Mail/SMTP) ---
# TOMATO_MAIL_ENABLED=false
# TOMATO_MAIL_HOST=smtp.example.com
# TOMATO_MAIL_PORT=465
# TOMATO_MAIL_USERNAME=no-reply@example.com
# TOMATO_MAIL_PASSWORD=your_smtp_auth_code
# TOMATO_MAIL_FROM_ADDRESS=no-reply@example.com
# TOMATO_MAIL_FROM_NAME="Tomato Coach"
# TOMATO_MAIL_USE_TLS=true
